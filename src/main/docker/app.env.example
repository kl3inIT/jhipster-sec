# Copy this file to ~/app/app.env on the production server and replace every placeholder.
# The production compose file at ~/app/app.yml reads these values via env_file.

APP_IMAGE=ghcr.io/kl3init/jhipster-sec:latest
DOCKER_NETWORK=app-network

SPRING_PROFILES_ACTIVE=prod
MANAGEMENT_PROMETHEUS_METRICS_EXPORT_ENABLED=true
_JAVA_OPTIONS=-Xmx512m -Xms256m

# Existing operator-managed PostgreSQL database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/jhipster-sec
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=admin123
SPRING_LIQUIBASE_URL=jdbc:postgresql://postgres:5432/jhipster-sec
SPRING_LIQUIBASE_USER=postgres
SPRING_LIQUIBASE_PASSWORD=admin123

# Mail remains operator-managed in production. Use your real SMTP host or relay.
SPRING_MAIL_HOST=127.0.0.1
SPRING_MAIL_PORT=25
JHIPSTER_MAIL_BASE_URL=http://27.118.20.28

# Generate a strong base64 secret before deployment.
JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=replace-with-a-long-random-base64-secret
